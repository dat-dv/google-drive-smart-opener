{
  "extends": "@electron-toolkit/tsconfig/tsconfig.web.json",
  "include": [
    "src/renderer/src/env.d.ts",
    "src/renderer/src/**/*",
    "src/renderer/src/**/*.tsx",
    "src/preload/*.d.ts",
    "packages/core/src/**/*",
    "packages/shared/src/**/*"
  ],
  "compilerOptions": {
    "composite": true,
    "jsx": "react-jsx",
    "baseUrl": ".",
    "paths": {
      "@renderer/*": [
        "src/renderer/src/*"
      ],
      "@core": [
        "packages/core/src/index.ts"
      ],
      "@core/*": [
        "packages/core/src/*"
      ],
      "@shared": [
        "packages/shared/src/index.ts"
      ],
      "@shared/*": [
        "packages/shared/src/*"
      ]
    }
  }
}
